POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=courses
POSTGRES_USER=courses_user
POSTGRES_PASSWORD=your_password_here
# TERM_FILTER=Spring  # optional: limit scrape to terms whose name contains this string
# SUBJECT_LIMIT=5     # optional: stop after N subjects per term (for testing)
# HEADLESS=false      # optional: show browser window (local only, not in Docker)
# SLOW_MO=300         # optional: ms delay between interactions (use with HEADLESS=false)
# RMP_SCHOOL_ID=U2Nob29sLTE0NDI=  # optional: Rate My Professors school ID (default: uOttawa)
